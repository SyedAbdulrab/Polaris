# Copy to .env.prod on the VM and fill in real values.
# `docker compose -f docker-compose.prod.yml --env-file .env.prod ...` reads from this.

# --- Database ---
POSTGRES_USER=polaris
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=polaris

# --- Auth ---
# Generate fresh random secrets on the VM:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-32-bytes-hex
JWT_REFRESH_SECRET=replace-with-different-32-bytes-hex

# --- Public-facing URL of the API ---
# This is baked into the web JS bundle at build time. The browser uses it to call the API.
# Use the EC2 public IP (or a DNS name) including the protocol and port.
# Example for IP-only deploy:
#   PUBLIC_API_URL=http://12.34.56.78:3000
PUBLIC_API_URL=http://CHANGE-ME:3000
