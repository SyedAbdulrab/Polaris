// Polaris — Prisma schema
// A personal life-metrics tracker: finances, streaks, goals, mood logs.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum IncomeType {
  SALARY
  COMMISSION
  PENSION
  OTHER
}

enum Frequency {
  ONE_TIME
  WEEKLY
  MONTHLY
  ANNUAL
}

enum StreakType {
  POSITIVE
  NEGATIVE
}

enum AccountKind {
  CHECKING
  SAVINGS
  CASH
  CREDIT_CARD
  INVESTMENT
  LOAN
  OTHER
}

enum TransactionKind {
  INFLOW
  OUTFLOW
  TRANSFER
  ADJUSTMENT
}

// ---------- Core ----------

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String?

  // Hashed refresh token for rotation. Null = logged out / never logged in.
  refreshTokenHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incomeSources    IncomeSource[]
  expenses         Expense[]
  goals            Goal[]
  metricSnapshots  MetricSnapshot[]
  streaks          Streak[]
  logEntries       LogEntry[]
  accounts         Account[]
  transactions     Transaction[]

  @@map("users")
}

// ---------- Money in ----------

model IncomeSource {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  type      IncomeType
  // Stored in minor units (e.g. cents) by convention via Decimal for precision.
  amount    Decimal    @db.Decimal(14, 2)
  frequency Frequency
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Real transactions that materialise this rule (e.g. May's actual paycheck).
  transactions Transaction[]

  @@index([userId])
  @@index([userId, isActive])
  @@map("income_sources")
}

// ---------- Money out ----------

model Expense {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  category  String
  amount    Decimal   @db.Decimal(14, 2)
  frequency Frequency
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, category])
  @@map("expenses")
}

// ---------- Goals ----------

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  targetAmount  Decimal   @db.Decimal(14, 2)
  currentAmount Decimal   @default(0) @db.Decimal(14, 2)
  deadline      DateTime?
  category      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("goals")
}

// ---------- Computed metric history (for trend charts) ----------

model MetricSnapshot {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The day this snapshot represents. We dedupe per (userId, date).
  date         DateTime
  projectedMRR Decimal  @db.Decimal(14, 2)
  totalIncome  Decimal  @db.Decimal(14, 2)
  totalExpenses Decimal @db.Decimal(14, 2)
  // savingsRate is a fraction in [-1, 1], stored with 4 decimal precision.
  savingsRate  Decimal  @db.Decimal(6, 4)
  netCashFlow  Decimal  @db.Decimal(14, 2)
  // Free-form bag for future metrics (best-case/worst-case scenarios, etc.)
  customMetrics Json?

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
  @@map("metric_snapshots")
}

// ---------- Streaks ----------

model Streak {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  type           StreakType
  currentCount   Int        @default(0)
  longestCount   Int        @default(0)
  lastLoggedDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("streaks")
}

// ---------- Logs (highs / lows / mood / tagged check-ins) ----------

model LogEntry {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date  DateTime
  mood  Int?     // 1..5 or 1..10 — agreed at the API layer
  note  String?
  tags  Json?    // string[] e.g. ["high", "win", "ran-5k"]
  // Optional numeric value (e.g. weight, hours-slept) when the entry tracks a number.
  value Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@map("log_entries")
}

// ---------- Accounts (real-world money buckets) ----------

model Account {
  id     String      @id @default(cuid())
  userId String
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  kind           AccountKind
  // Each account stores values in its OWN native currency. Aggregation across
  // accounts (e.g. net worth in display currency) happens client-side using FX rates.
  currency       String      @db.VarChar(8)
  // Optional bank/issuer label, free-form. e.g. "HBL", "Vanguard", "Apple Card".
  institution    String?
  openingBalance Decimal     @default(0) @db.Decimal(16, 2)
  openingDate    DateTime
  isActive       Boolean     @default(true)
  archivedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Transactions that hit this account directly.
  transactions     Transaction[] @relation("AccountTransactions")
  // Transactions where this account is the *destination* of a transfer.
  incomingTransfers Transaction[] @relation("AccountIncomingTransfers")

  @@index([userId])
  @@index([userId, isActive])
  @@map("accounts")
}

// ---------- Transactions (actual money-moving events) ----------

model Transaction {
  id     String          @id @default(cuid())
  userId String
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId String
  account   Account       @relation("AccountTransactions", fields: [accountId], references: [id], onDelete: Cascade)

  date        DateTime
  // Always positive. Direction is encoded by `kind`.
  // Stored in the *account's* native currency.
  amount      Decimal         @db.Decimal(16, 2)
  kind        TransactionKind
  // Free-form category, mirrors Expense.category for OUTFLOWs. For INFLOWs use
  // tags like "salary", "freelance", "refund".
  category    String?
  description String?

  // Optional links back to recurring rules so we can answer
  // "did May's projected $5k salary actually hit?".
  sourceIncomeId  String?
  sourceIncome    IncomeSource? @relation(fields: [sourceIncomeId], references: [id], onDelete: SetNull)
  sourceExpenseId String?
  sourceExpense   Expense?      @relation(fields: [sourceExpenseId], references: [id], onDelete: SetNull)

  // For TRANSFER transactions, the other side. The `amount` is debited from
  // `account` and credited (in its own currency) to `transferToAccount` —
  // cross-currency transfers track each side independently.
  transferToAccountId String?
  transferToAccount   Account? @relation("AccountIncomingTransfers", fields: [transferToAccountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([accountId, date])
  @@index([userId, sourceIncomeId])
  @@index([userId, sourceExpenseId])
  @@map("transactions")
}
