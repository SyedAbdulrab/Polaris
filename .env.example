# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://polaris:polaris@localhost:5432/polaris?schema=public

# --- Cache / queues (Redis) ---
# Used in Phase 2+ for caching computed metrics and scheduled snapshot jobs.
REDIS_URL=redis://localhost:6379

# --- Auth (JWT, access + refresh tokens) ---
# Use long random strings in any non-dev environment. They MUST differ from each other.
JWT_ACCESS_SECRET=replace-me-access-secret-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-refresh-secret-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Rate limiting (requests / TTL seconds, applied globally) ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120
